APP_ENV=production
APP_DEBUG=false
APP_ALLOWED_ORIGINS=https://highlightsignal.com

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=replace_database_name
DB_USER=replace_database_user
DB_PASSWORD=replace_database_password

# Must equal Next.js PHP_SERVICE_AUTH_SECRET (minimum 32 random characters).
SERVICE_AUTH_SECRET=replace-with-at-least-32-random-characters
SERVICE_AUTH_TTL_SECONDS=60

OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4.1-mini
SI_AI_POLISH_ENABLED=false

PAGESPEED_API_KEY=
# Absolute server path. Do not place the credential JSON inside the public API folder.
# Use a path inside the hosting account's open_basedir allowance.
GOOGLE_APPLICATION_CREDENTIALS=/raid/vhost/highlight.url.tw/private/google-service-account.json
# Alternatively, provide the complete service-account JSON as one environment value.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
