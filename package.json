{
  "name": "highlightsignal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "next build --webpack",
    "build:cf": "opennextjs-cloudflare build",
    "typecheck": "tsc --noEmit --pretty false",
    "types:cf": "wrangler types --env production --no-include-runtime --check",
    "verify:release-boundary": "node scripts/verify-release-boundary.mjs",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "dry-run:cf:staging": "wrangler deploy --env staging --dry-run",
    "dry-run:cf:production": "wrangler deploy --env production --dry-run",
    "deploy:cf:staging": "opennextjs-cloudflare build && wrangler deploy --env staging",
    "deploy:cf:production": "opennextjs-cloudflare build && wrangler deploy --env production",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "client-only": "^0.0.1",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.3",
    "lucide-react": "^0.554.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.5.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4.81.0"
  }
}
