# Copy to backend/private/frontend.env for local development. Do not use a
# Next.js .env* file for server-only secrets because OpenNext can bundle it.
NEXT_PUBLIC_BASE_URL=https://highlightsignal.com
NEXT_PUBLIC_HIGHLIGHT_PHP_API_BASE_URL=https://www.highlight.url.tw/highlightsignal/v2
NEXT_PUBLIC_HIGHLIGHT_UPGRADE_URL=https://www.highlight.url.tw/shop/product.html?id=3
API_DOMAIN=https://www.highlight.url.tw
JWT_SECRET=replace-with-a-long-random-secret
PHP_SERVICE_AUTH_SECRET=replace-with-the-same-32-byte-secret-as-backend
